## launch alacritty with bspwm config

#CONFIG="$HOME/.config/bspwm/alacritty/alacritty.yml"

if [ "$1" == "-f" ]; then
	kitty --class 'kitty-float,kitty-float'
elif [ "$1" == "-s" ]; then
	kitty --class 'Fullscreen,Fullscreen' -o window.startup_mode=fullscreen window.padding.x=30 window.padding.y=30 window.opacity=0.95 font.size=14
else
	kitty
fi
